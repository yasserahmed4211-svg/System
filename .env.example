# ============================================
# ERP System — Local Development Environment Variables
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control (.gitignore already excludes it)
# ============================================

# Required: activate dev profile for local development
SPRING_PROFILES_ACTIVE=dev

# Database — local Oracle
DB_URL=jdbc:oracle:thin:@localhost:1521:orcl
DB_USERNAME=test
DB_PASSWORD=test

# JWT — dev value only (min 256 bits). Override with a real secret if needed.
JWT_SECRET=dev-only-secret-minimum-256-bits-long-do-not-use-in-prod
